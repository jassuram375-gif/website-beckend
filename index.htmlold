<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Travel Planner & Wardrobe Guide</title>
    <!-- Connecting your CSS file -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Main Container for Layout Positioning -->
    <div class="main-wrapper">
        
        <!-- Section 1: Trip Planner Form -->
        <div class="form-container">
            <h2>Plan Your Trip</h2>
            <form id="travelForm">
                <div class="form-group">
                    <label for="destination">Destination:</label>
                    <input type="text" id="destination" name="destination" placeholder="e.g., Uttarakhand, Srinagar, Manali" required>
                </div>

                <div class="form-group">
                    <label for="days">Number of Days:</label>
                    <input type="number" id="days" name="days" placeholder="e.g., 5" min="1" required>
                </div>

                <button type="submit">Calculate Trip Cost</button>
            </form>
        </div>

        <!-- Section 2: Curated Travel Wardrobe -->
        <div class="apparel-container">
            <h3>Recommended Travel Wardrobe</h3>
            <div class="apparel-grid">
                <div class="apparel-card">
                    <h4>Traditional & Heritage Aesthetic</h4>
                    <p><strong>Style:</strong> Classic Pathani Suit</p>
                    <p>Perfect for cultural site-seeing, evening dinners, and local heritage exploration.</p>
                </div>
                <div class="apparel-card">
                    <h4>Classic Casual & Comfort</h4>
                    <p><strong>Style:</strong> Gurkha Pants & Linen Shirts</p>
                    <p>Ideal for staying sharp, breathable, and comfortable while traveling or walking through cities.</p>
                </div>
            </div>
        </div>

    </div>

    <!-- Connecting your JavaScript Bridge Code -->
    <script src="script.js"></script>
</body>
</html>